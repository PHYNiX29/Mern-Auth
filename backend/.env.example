# ── MongoDB Atlas ──────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/primetrade?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Redis ─────────────────────────────────────
# In Docker Compose, this points to the redis service name
REDIS_URL=redis://redis:6379

# ── App ───────────────────────────────────────
PORT=8000
NODE_ENV=production

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── CORS ──────────────────────────────────────
# Frontend origin (no trailing slash)
FRONTEND_URL=http://localhost:3000
